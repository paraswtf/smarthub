generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────

model Account {
    id                       String  @id @default(auto()) @map("_id") @db.ObjectId
    userId                   String  @db.ObjectId
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    sessionToken String   @unique
    userId       String   @db.ObjectId
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(auto()) @map("_id") @db.ObjectId
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    passwordHash  String?
    accounts      Account[]
    sessions      Session[]
    apiKeys       ApiKey[]
}

model VerificationToken {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── ESP Hub ─────────────────────────────────────────────────

model ApiKey {
    id         String    @id @default(auto()) @map("_id") @db.ObjectId
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    key        String    @unique
    label      String    @default("My Key")
    active     Boolean   @default(true)
    lastUsedAt DateTime?
    userId     String    @db.ObjectId
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    devices    Device[]
}

model Device {
    id              String     @id @default(auto()) @map("_id") @db.ObjectId
    createdAt       DateTime   @default(now())
    updatedAt       DateTime   @updatedAt
    name            String     @default("ESP32 Device")
    macAddress      String     @unique
    firmwareVersion String?
    ssid            String?
    lastSeenAt      DateTime?
    notes           String?
    apiKeyId        String     @db.ObjectId
    apiKey          ApiKey     @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
    relays          Relay[]
    detectors       Detector[]
}

model Relay {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    pin       Int
    label     String   @default("Relay")
    state     Boolean  @default(false)
    order     Int      @default(0)
    icon      String   @default("plug")
    deviceId  String   @db.ObjectId
    device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// A detector monitors an input GPIO pin and controls a relay on state change.
// mode "toggle"  — any change on the input pin flips the relay state
// mode "follow"  — relay mirrors the pin state (HIGH=ON, LOW=OFF)
model Detector {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    pin          Int
    label        String   @default("Switch")
    mode         String   @default("toggle")      // "toggle" | "follow"
    switchType   String   @default("latching")    // "latching" | "momentary"
    linkedRelayId String   @db.ObjectId
    pullMode     String   @default("pullup")      // "pullup" | "pulldown" — only used for follow mode
    deviceId     String   @db.ObjectId
    device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}
