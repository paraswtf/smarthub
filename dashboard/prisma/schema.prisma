generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────

model Account {
    id                       String  @id @default(auto()) @map("_id") @db.ObjectId
    userId                   String  @db.ObjectId
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    sessionToken String   @unique
    userId       String   @db.ObjectId
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String       @id @default(auto()) @map("_id") @db.ObjectId
    name          String?
    email         String?      @unique
    emailVerified DateTime?
    image         String?
    passwordHash  String?
    accounts      Account[]
    sessions      Session[]
    apiKeys       ApiKey[]
    homes         Home[]
    sharedHomes   HomeShare[]  @relation("SharedHomes")
    sharedRooms   RoomShare[]  @relation("SharedRooms")
    sharedRelays  RelayShare[] @relation("SharedRelays")
}

model VerificationToken {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── SmartHUB ────────────────────────────────────────────────

// Additional WiFi networks pushed to the ESP32 from the dashboard.
// wn0 (captive portal primary) lives in ESP32 NVS only - password is never sent to the server.
// Passwords here are stored in plaintext; acceptable for self-hosted IoT deployments.
type WifiNetwork {
    ssid     String
    password String
}

model ApiKey {
    id         String    @id @default(auto()) @map("_id") @db.ObjectId
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
    key        String    @unique
    label      String    @default("My Key")
    active     Boolean   @default(true)
    lastUsedAt DateTime?
    userId     String    @db.ObjectId
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    devices    Device[]
}

model Device {
    id                 String        @id @default(auto()) @map("_id") @db.ObjectId
    createdAt          DateTime      @default(now())
    updatedAt          DateTime      @updatedAt
    name               String        @default("ESP32 Device")
    macAddress         String        @unique
    firmwareVersion    String?
    ssid               String?
    notes              String?
    lastSeenAt         DateTime?
    apiKeyId           String        @db.ObjectId
    apiKey             ApiKey        @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
    homeId             String?       @db.ObjectId
    home               Home?         @relation(fields: [homeId], references: [id])
    relays             Relay[]
    switches           Switch[]
    // Dashboard-managed WiFi networks (pushed to ESP32 via WS; does not include captive-portal primary)
    wifiNetworks       WifiNetwork[]
    // Desired server config - pushed to ESP32 via WS when changed from dashboard
    cfgServerHost      String?
    cfgServerPort      Int?
    cfgServerTLS       Boolean?
    // Reported by ESP32 on registration - what host/port it is actually connecting to
    reportedServerHost String?
    reportedServerPort Int?
}

model Relay {
    id        String          @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime        @default(now())
    updatedAt DateTime        @updatedAt
    pin       Int
    label     String          @default("Relay")
    state     Boolean         @default(false)
    order     Int             @default(0)
    icon      String          @default("plug")
    deviceId  String          @db.ObjectId
    device    Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
    roomId    String?         @db.ObjectId
    room      Room?           @relation(fields: [roomId], references: [id])
    shares    RelayShare[]
    schedules RelaySchedule[]
}

// A switch monitors an input GPIO pin and toggles a linked relay on state change.
// switchType "two_way"   - SPST: VCC ↔ floating (INPUT_PULLDOWN), toggles on change
// switchType "three_way" - SPDT: VCC ↔ GND (INPUT, no pull), toggles on change
// switchType "momentary" - push button (INPUT_PULLDOWN + ISR RISING), toggles on press
model Switch {
    id            String   @id @default(auto()) @map("_id") @db.ObjectId
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    pin           Int
    label         String   @default("Switch")
    switchType    String   @default("two_way")
    linkedRelayId String   @db.ObjectId
    deviceId      String   @db.ObjectId
    device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// ─── Homes, Rooms & Sharing ─────────────────────────────────

model Home {
    id        String      @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    name      String      @default("My Home")
    ownerId   String      @db.ObjectId
    owner     User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    devices   Device[]
    rooms     Room[]
    shares    HomeShare[]
}

model Room {
    id        String      @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    name      String      @default("Room")
    order     Int         @default(0)
    homeId    String      @db.ObjectId
    home      Home        @relation(fields: [homeId], references: [id], onDelete: Cascade)
    relays    Relay[]
    shares    RoomShare[]
}

model HomeShare {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime @default(now())
    homeId    String   @db.ObjectId
    home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)
    userId    String   @db.ObjectId
    user      User     @relation("SharedHomes", fields: [userId], references: [id], onDelete: Cascade)

    @@unique([homeId, userId])
}

model RoomShare {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime @default(now())
    roomId    String   @db.ObjectId
    room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
    userId    String   @db.ObjectId
    user      User     @relation("SharedRooms", fields: [userId], references: [id], onDelete: Cascade)

    @@unique([roomId, userId])
}

model RelayShare {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    createdAt DateTime @default(now())
    relayId   String   @db.ObjectId
    relay     Relay    @relation(fields: [relayId], references: [id], onDelete: Cascade)
    userId    String   @db.ObjectId
    user      User     @relation("SharedRelays", fields: [userId], references: [id], onDelete: Cascade)

    @@unique([relayId, userId])
}

model RelaySchedule {
    id          String    @id @default(auto()) @map("_id") @db.ObjectId
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    label       String    @default("Schedule")
    hour        Int
    minute      Int
    daysOfWeek  Int[]
    action      Boolean
    enabled     Boolean   @default(true)
    timezone    String    @default("Asia/Kolkata")
    lastFiredAt DateTime?
    relayId     String    @db.ObjectId
    relay       Relay     @relation(fields: [relayId], references: [id], onDelete: Cascade)
    createdById String    @db.ObjectId
}
