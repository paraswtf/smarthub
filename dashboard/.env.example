# Database — local MongoDB (Docker container with replica set)
DATABASE_URL="mongodb://localhost:27017/esphub?replicaSet=rs0&directConnection=true"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""

# Brevo — transactional email (API)
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""

# ─── WebSocket Server ───
WS_PORT=4001
NEXT_PUBLIC_WS_PORT=4001

# Secret shared between Next.js and WS server for internal push calls
WS_SECRET="change-me-to-a-random-secret"

# Internal URL of the WS server (used by tRPC → WS server HTTP calls)
WS_INTERNAL_URL="http://localhost:4001"

# Next.js base URL
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"
