# Database — Prisma Accelerate (MongoDB)
# Get this from https://console.prisma.io → your project → Accelerate
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"

# NextAuth
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Brevo — transactional email for contact form notifications
# Get API key from https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="website@rivant.in"   # must be a verified sender in Brevo

# Upstash Redis — rate limiting (5 submissions per IP per hour)
# Get from https://console.upstash.com → Create Database → REST API
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ─── ESP Hub additions ──────────────────────────────────
# Standalone WebSocket server port
WS_PORT=4001
NEXT_PUBLIC_WS_PORT=4001

# Secret shared between Next.js and WS server for internal push calls
WS_SECRET="change-me-to-a-random-secret"

# Internal URL of the WS server (used by /api/esp/ws-relay)
WS_INTERNAL_URL="http://localhost:4001"

# Next.js base URL (used for callbacks)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"
