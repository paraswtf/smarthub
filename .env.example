# ─── Secrets ───
AUTH_SECRET=          # generate with: openssl rand -base64 32
WS_SECRET=            # generate with: openssl rand -base64 32
WEBHOOK_SECRET=       # set in GitHub webhook config

# ─── Public URLs (baked into Next.js at build time) ───
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3000
NEXT_PUBLIC_WS_PORT=4001

# ─── Google OAuth ───
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# ─── Email (Brevo API) ───
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
